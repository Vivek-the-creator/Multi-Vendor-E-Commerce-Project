{
  "name": "multi-vendor-ecommerce",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise-grade dynamic multi-vendor e-commerce marketplace.",
  "workspaces": [
    "backend",
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:backend": "npm --workspace @marketplace/backend run dev",
    "dev:frontend": "npm --workspace @marketplace/frontend run dev",
    "dev:api": "npm run dev:backend",
    "dev:web": "npm run dev:frontend",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write .",
    "db:seed": "npm --workspace @marketplace/backend run db:seed"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
